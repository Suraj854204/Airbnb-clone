<% layout('layouts/boilerplate') %>

<!-- Heading -->
<div class="row mt-3">
  <div class="col-6 offset-3">
    <h3><%= listing.title %></h3>
  </div>
</div>

<!-- Card -->
<div class="row">
  <div class="col-6 offset-3 listing-card">
      <img 
        src="<%= listing.image.url %>" 
        class="card-img-top show-img" 
        alt="listing-image"
      >

      <div class="card-body">
        <p class="card-text"><i>Owned by <%= listing.owner ? listing.owner.username : 'Unknown' %></i></p>
        <p class="card-text"><%= listing.description %></p>
        <p class="card-text">₹<%= listing.price.toLocaleString("en-IN") %></p>
        <p class="card-text"><%= listing.location %></p>
        <p class="card-text"><%= listing.country %></p>
    </div>
  </div>
</div>

<!-- Edit/Delete buttons - Only visible to owner -->
<% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
  <div class="row mt-3 mb-3">
    <div class="col-6 offset-3">
      <div class="btns">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-edit btn-sm">Edit</a>
        <form 
          class="d-inline"
          action="/listings/<%= listing._id %>?_method=DELETE" method="POST"
        >
          <button type="submit" class="btn btn-delete btn-sm">
            Delete
          </button>
        </form>
      </div>
    </div>
  </div>
<% } %>

<!-- Review Section -->
<div class="row mt-3 mb-3">
  <div class="col-6 offset-3">
    <hr class="my-2">
    <h4>Leave a Review</h4>
    
    <!-- Only show review form if user is logged in -->
    <% if(currUser) { %>
      <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
        <div class="mb-2">
          <label for="rating" class="form-label">Rating:</label>
          <input type="range" min="1" max="5" name="review[rating]" class="form-range" id="rating">
        </div>
        <div class="mb-2">
          <label for="comment" class="form-label">Comment:</label>
          <textarea 
            name="review[comment]" 
            id="comment" 
            rows="5" 
            cols="30" 
            class="form-control" required>
          </textarea>
          <div class="invalid-feedback">
            Please submit some comment for review.
          </div>
        </div>
        <button type="submit" class="btn btn-dark">
          Submit 
        </button>
      </form>
    <% } else { %>
      <p><a href="/login">Login</a> to leave a review.</p>
    <% } %>

    <hr>

    <p><b>All reviews:</b></p>
    <div class="row">
    <% if(listing.reviews && listing.reviews.length > 0) { %>
      <% for(let review of listing.reviews) { %>
        <div class="card col-5 ms-3 mb-3">
          <div class="card-body">
            <h5 class="card-title"><%= review.author ? review.author.username : 'Anonymous' %></h5>
            <p class="card-text"><%= review.comment %></p>
            <p class="card-text"><%= review.rating %>/5 Stars</p>
            
            <!-- Only show delete button if user is review author or listing owner -->
            <% if(currUser && (currUser._id.equals(review.author?._id) || currUser._id.equals(listing.owner?._id))) { %>
              <form 
                class="mb-3"
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST"
              >
                <button type="submit" class="btn btn-delete btn-sm">
                  Delete
                </button>
              </form>
            <% } %>
          </div>
        </div>
      <% } %>
    <% } else { %>
      <p class="col-12">No reviews yet. Be the first to review!</p>
    <% } %>
    </div>

  </div>
</div>